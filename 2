<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prépa Brevet — Maths</title><style>
:root {
 --blue:#0021BC;--blue-lt:#BDD4E7;--orange:#EE6E34;--rose:#D0A6C6;
 --bg:#EDEEF0;--white:#FFFFFF;--ink:rgb(25,8,6);--muted:#8A8DAA;
 --fd:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
 --fb:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--ink);font-family:var(--fb);-webkit-font-smoothing:antialiased}
.page{display:none}.page.active{display:block}

/* NAV */
.nav{display:flex;justify-content:space-between;align-items:flex-start;padding:28px 48px 0;z-index:10;position:relative}
.logo{cursor:pointer}
.logo-top{font-size:13px;color:var(--ink);display:block}
.logo-bot{font-family:var(--fd);font-size:36px;font-weight:800;letter-spacing:-.04em;line-height:.9;text-transform:uppercase;display:block}
.logo-bot span{color:var(--blue)}
.nav-r{display:flex;align-items:center;gap:32px}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links li{font-size:14px;opacity:.6;cursor:pointer;transition:opacity .15s}
.nav-links li:hover,.nav-links li.on{opacity:1}
.nav-links li.on{font-weight:500}
.cta{font-family:var(--fd);font-size:13px;font-weight:600;background:var(--blue);color:#fff;padding:11px 24px;border-radius:100px;border:none;cursor:pointer;transition:opacity .15s}
.cta:hover{opacity:.85}

/* UTILS */
.divider{height:1px;background:rgba(0,0,0,.1);margin:0 48px}
.eyebrow{font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:10px}
.eyebrow::before{content:'';width:20px;height:2px;background:var(--orange);border-radius:2px;display:inline-block}
.btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--fd);font-size:13px;font-weight:600;padding:13px 28px;border-radius:100px;cursor:pointer;border:none;text-transform:lowercase;transition:opacity .15s}
.btn:hover{opacity:.85}
.btn-blue{background:var(--blue);color:#fff}
.btn-orange{background:var(--orange);color:#fff}
.btn-ghost{background:transparent;color:var(--ink);border:1.5px solid rgba(0,0,0,.15);padding:12px 26px}
.ctag{font-size:10px;font-weight:500;padding:4px 12px;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);color:var(--muted);background:transparent}
.ctag.b{background:#EEF2FF;border-color:var(--blue);color:var(--blue)}
.ctag.o{background:#FFF0E8;border-color:var(--orange);color:var(--orange)}
.ctag.r{background:#F9F0F7;border-color:var(--rose);color:#8B5A7A}

/* STATS STRIP */
.stats{display:grid;grid-template-columns:repeat(4,1fr);padding:0 48px}
.stat{padding:40px 32px;border-right:1px solid rgba(0,0,0,.08)}
.stat:last-child{border-right:none}
.stat-n{font-family:var(--fd);font-size:64px;font-weight:500;letter-spacing:-.04em;line-height:1;text-transform:lowercase;margin-bottom:8px}
.stat-l{font-size:13px;color:var(--muted);font-weight:300;line-height:1.5;max-width:180px}

/* SECTION */
.sec{padding:56px 48px;border-top:1px solid rgba(0,0,0,.08)}
.sec-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:36px}
.sec-title{font-family:var(--fd);font-size:clamp(28px,3.5vw,48px);font-weight:500;text-transform:lowercase;letter-spacing:-.03em;line-height:1}
.see-all{font-size:13px;font-weight:500;color:var(--blue);cursor:pointer}

/* CARDS ANNALES */
.chap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.chap-card{background:var(--white);padding:28px;cursor:pointer;transition:background .15s}
.chap-card:hover{background:#F4F5F8}
.chap-card:nth-child(1){border-radius:16px 0 0 0}
.chap-card:nth-child(3){border-radius:0 16px 0 0}
.chap-card:nth-child(4){border-radius:0 0 0 0;margin-top:2px}
.chap-card:nth-child(6){border-radius:0 0 16px 0;margin-top:2px}
.chap-card:nth-child(5){margin-top:2px}
.chap-num{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.chap-title{font-family:var(--fd);font-size:18px;font-weight:500;text-transform:lowercase;letter-spacing:-.02em;margin-bottom:4px}
.chap-meta{font-size:12px;color:var(--muted);font-weight:300;margin-bottom:16px}
.chap-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.bar-wrap{display:flex;align-items:center;gap:10px}
.bar{flex:1;height:5px;background:rgba(0,0,0,.07);border-radius:100px;overflow:hidden}
.bar-fill{height:100%;border-radius:100px}
.bar-pct{font-family:'Courier New',monospace;font-size:11px;font-weight:700;white-space:nowrap}

/* FOOTER */
.footer-top{padding:48px 48px 36px;display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:40px;border-top:1px solid rgba(0,0,0,.08)}
.footer-logo-bot{font-family:var(--fd);font-size:26px;font-weight:800;letter-spacing:-.04em;text-transform:uppercase;line-height:.95;margin-bottom:12px}
.footer-logo-bot span{color:var(--blue)}
.footer-desc{font-size:12px;color:var(--muted);font-weight:300;line-height:1.65}
.footer-col-title{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-links li{font-size:13px;color:rgba(0,0,0,.45);cursor:pointer;font-weight:300}
.footer-links li:hover{color:var(--ink)}
.footer-email-wrap{padding:0 48px;border-top:1px solid rgba(0,0,0,.08);display:flex;align-items:center;gap:16px}
.footer-email{font-family:var(--fd);font-size:clamp(24px,4vw,56px);font-weight:500;color:var(--ink);letter-spacing:-.04em;text-transform:lowercase;padding:28px 0;text-decoration:none;transition:color .15s}
.footer-email:hover{color:var(--blue)}
.footer-bar{background:var(--blue);padding:16px 48px;display:flex;justify-content:space-between;align-items:center}
.footer-bar-links{display:flex;gap:40px}
.footer-bar-links a{font-size:13px;font-weight:500;color:rgba(255,255,255,.7);text-decoration:none;cursor:pointer}
.footer-bar-links a:hover{color:#fff}
.footer-bar-copy{font-size:12px;color:rgba(255,255,255,.35)}

/* PAGE PARCOURS */
.prog-row{display:grid;grid-template-columns:1fr 1fr 80px 110px;align-items:center;gap:16px;padding:16px 22px;background:var(--white)}
.prog-name{font-family:var(--fd);font-size:14px;font-weight:500;text-transform:lowercase;letter-spacing:-.01em}
.prog-bar{height:7px;background:rgba(0,0,0,.07);border-radius:100px;overflow:hidden}
.prog-bar-fill{height:100%;border-radius:100px}
.prog-pct{font-family:'Courier New',monospace;font-size:13px;font-weight:700;text-align:right}
.prog-btn{font-family:var(--fd);font-size:11px;font-weight:600;padding:7px 12px;border-radius:100px;border:none;cursor:pointer;text-transform:lowercase;text-align:center}

/* PAGE RESSOURCES */
.res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.res-card{background:var(--white);overflow:hidden;cursor:pointer;transition:background .15s}
.res-card:hover{background:#F4F5F8}
.res-card:first-child{border-radius:16px 0 0 16px}
.res-card:last-child{border-radius:0 16px 16px 0}
.res-card-top{height:100px;display:flex;align-items:center;justify-content:center;font-size:40px;border-bottom:1px solid rgba(0,0,0,.06)}
.res-card-body{padding:20px}
.res-type{font-size:10px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.res-name{font-family:var(--fd);font-size:14px;font-weight:500;text-transform:lowercase;letter-spacing:-.01em;margin-bottom:4px;line-height:1.3}
.res-meta{font-size:12px;color:var(--muted);font-weight:300}

/* PAGE ABONNEMENT */
.pricing-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;max-width:820px}
.plan{border-radius:20px;padding:40px}
.plan-free{background:var(--white);border:2px solid rgba(0,0,0,.06)}
.plan-pro{background:var(--blue)}
.plan-label{font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;margin-bottom:18px}
.plan-price{font-family:var(--fd);font-size:68px;font-weight:500;letter-spacing:-.04em;line-height:1;text-transform:lowercase;margin-bottom:4px}
.plan-period{font-size:13px;margin-bottom:28px}
.plan-features{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
.plan-feat{display:flex;align-items:center;gap:10px;font-size:13px}
.feat-check{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
.plan-cta{width:100%;font-family:var(--fd);font-size:14px;font-weight:600;border:none;border-radius:100px;padding:15px;cursor:pointer;text-transform:lowercase}

/* PAGE GENERER */
.gen-layout{display:grid;grid-template-columns:1fr 1fr;min-height:calc(100vh - 90px)}
.gen-left{padding:48px;border-right:1px solid rgba(0,0,0,.08);display:flex;flex-direction:column;gap:40px}
.gen-right{padding:48px;display:flex;flex-direction:column;gap:32px}
.gen-label{font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.duree-list{display:flex;flex-direction:column;gap:8px}
.duree-chip{width:100%;font-family:var(--fd);font-size:12px;font-weight:500;padding:7px 11px;border-radius:7px;border:1.5px solid rgba(0,0,0,.08);background:var(--white);color:var(--ink);cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:all .15s;letter-spacing:-.01em}
.duree-chip:hover{border-color:var(--blue);color:var(--blue)}
.duree-chip.sel{background:var(--blue);border-color:var(--blue);color:#fff}
.duree-sub{font-size:12px;font-weight:300;opacity:.6;font-family:var(--fb)}
.notions-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.notion-chip{font-size:11px;padding:7px 10px;border-radius:7px;border:1.5px solid rgba(0,0,0,.08);background:var(--white);color:var(--ink);cursor:pointer;text-align:left;display:flex;align-items:center;gap:7px;transition:all .15s}
.notion-chip:hover{border-color:var(--blue);color:var(--blue)}
.notion-chip.sel{background:#EEF2FF;border-color:var(--blue);color:var(--blue);font-weight:500}
.notion-chip.all-chip{grid-column:1/-1;font-family:var(--fd);font-size:14px;font-weight:500}
.notion-chip.all-chip.sel{background:var(--ink);border-color:var(--ink);color:#fff}
.ncheck{width:18px;height:18px;border-radius:5px;border:1.5px solid rgba(0,0,0,.15);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .15s}
.notion-chip.sel .ncheck{background:var(--blue);border-color:var(--blue);color:#fff}
.notion-chip.all-chip.sel .ncheck{background:#fff;border-color:#fff;color:var(--ink)}
.corr-list{display:flex;flex-direction:column;gap:8px}
.corr-chip{width:100%;display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-radius:9px;border:1.5px solid rgba(0,0,0,.08);background:var(--white);cursor:pointer;transition:all .15s}
.corr-chip:hover{border-color:var(--blue)}
.corr-chip.sel{background:#EEF2FF;border-color:var(--blue)}
.corr-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.corr-title{font-family:var(--fd);font-size:14px;font-weight:500;color:var(--ink);letter-spacing:-.01em;margin-bottom:2px}
.corr-chip.sel .corr-title{color:var(--blue)}
.corr-sub{font-size:12px;color:var(--muted);font-weight:300}
.ccheck{width:20px;height:20px;border-radius:6px;border:1.5px solid rgba(0,0,0,.15);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .15s}
.corr-chip.sel .ccheck{background:var(--blue);border-color:var(--blue);color:#fff}
.gen-recap{background:var(--white);border-radius:18px;padding:28px;display:flex;flex-direction:column;gap:18px}
.recap-title{font-family:var(--fd);font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.recap-big{font-family:var(--fd);font-size:56px;font-weight:500;letter-spacing:-.04em;line-height:1;color:var(--blue);text-transform:lowercase}
.recap-tags{display:flex;flex-wrap:wrap;gap:6px}
.recap-tag{font-size:11px;font-weight:500;padding:4px 12px;border-radius:100px;background:#EEF2FF;color:var(--blue);border:1px solid var(--blue-lt)}
.recap-tag.all{background:var(--ink);color:#fff;border-color:var(--ink)}
.gen-cta{display:flex;flex-direction:column;gap:10px}
.gen-btn{font-family:var(--fd);font-size:12px;font-weight:600;padding:11px;border-radius:100px;border:none;cursor:pointer;text-transform:lowercase;text-align:center;transition:opacity .15s}
.gen-btn:hover{opacity:.85}
.gen-btn-blue{background:var(--blue);color:#fff}
.gen-btn-ghost{background:transparent;color:var(--muted);border:1.5px solid rgba(0,0,0,.12)}

/* PAGE BREVET */
.brevet-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 0;gap:20px}
.spinner{width:40px;height:40px;border:3px solid rgba(0,33,188,.15);border-top-color:var(--blue);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.brevet-ex{background:var(--white);border-radius:18px;padding:32px;margin-bottom:14px}
.brevet-ex-num{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:4px}
.brevet-ex-titre{font-family:var(--fd);font-size:20px;font-weight:500;text-transform:lowercase;letter-spacing:-.02em;display:block}
.brevet-enonce{font-size:14px;line-height:1.75;color:#3A3D6B;background:rgba(0,33,188,.03);border-left:3px solid var(--blue-lt);padding:14px 18px;border-radius:0 10px 10px 0;margin:18px 0 22px}
.brevet-q{margin-bottom:20px}
.brevet-q-row{display:flex;align-items:baseline;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.brevet-q-id{font-family:var(--fd);font-size:13px;font-weight:700;color:var(--blue);flex-shrink:0}
.brevet-q-text{font-size:14px;color:var(--ink);line-height:1.5;flex:1}
.brevet-q-pts{font-size:11px;font-weight:700;color:var(--orange);background:#FFF0E8;padding:3px 10px;border-radius:100px;white-space:nowrap}
.brevet-answer{width:100%;font-family:var(--fb);font-size:14px;color:var(--ink);background:#FAFAFA;border:1.5px solid rgba(0,0,0,.08);border-radius:10px;padding:12px 14px;resize:vertical;transition:border-color .15s;line-height:1.6}
.brevet-answer:focus{outline:none;border-color:var(--blue);background:var(--white)}
.brevet-answer::placeholder{color:var(--muted)}
.brevet-answer:disabled{opacity:.6;cursor:not-allowed}
/* QCM boutons */
.qcm-options{display:flex;flex-direction:column;gap:8px;margin-top:16px}
.qcm-btn{display:flex;align-items:center;gap:0;border-radius:12px;border:1.5px solid rgba(0,0,0,.08);background:var(--white);cursor:pointer;transition:all .18s;user-select:none;font-family:var(--fb);text-align:left;width:100%;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.qcm-btn:hover:not(:disabled){border-color:var(--blue);box-shadow:0 3px 10px rgba(0,33,188,.1);transform:translateX(3px)}
.qcm-btn.selected{border-color:var(--blue);box-shadow:0 3px 10px rgba(0,33,188,.12)}
.qcm-btn.correct{border-color:#22C55E;box-shadow:0 3px 10px rgba(34,197,94,.15);pointer-events:none}
.qcm-btn.wrong{border-color:#EF4444;box-shadow:0 3px 10px rgba(239,68,68,.12);pointer-events:none}
.qcm-btn.missed{border-color:#22C55E;opacity:.75;pointer-events:none}
.qcm-btn:disabled{cursor:not-allowed}
.qcm-btn-letter{width:52px;min-height:52px;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:15px;font-weight:800;flex-shrink:0;transition:all .18s;color:var(--muted);background:rgba(0,0,0,.03);border-right:1.5px solid rgba(0,0,0,.06);letter-spacing:-.01em}
.qcm-btn.selected .qcm-btn-letter{background:var(--blue);color:#fff;border-right-color:var(--blue)}
.qcm-btn.correct .qcm-btn-letter{background:#22C55E;color:#fff;border-right-color:#22C55E}
.qcm-btn.wrong .qcm-btn-letter{background:#EF4444;color:#fff;border-right-color:#EF4444}
.qcm-btn.missed .qcm-btn-letter{background:#22C55E;color:#fff;border-right-color:#22C55E}
.qcm-btn-label{font-size:14px;color:var(--ink);line-height:1.45;flex:1;padding:14px 18px}
.qcm-btn.selected .qcm-btn-label{color:var(--blue);font-weight:500}
.qcm-btn.correct .qcm-btn-label{color:#166534;font-weight:500}
.qcm-btn.wrong .qcm-btn-label{color:#991B1B}
.qcm-btn-icon{font-size:16px;padding-right:16px;opacity:0;transition:opacity .15s}
.qcm-btn.correct .qcm-btn-icon,.qcm-btn.wrong .qcm-btn-icon{opacity:1}
.corr-btn{font-size:12px;font-weight:600;padding:8px 20px;border-radius:100px;border:1.5px solid var(--blue);background:transparent;color:var(--blue);cursor:pointer;transition:all .15s;margin-top:6px}
.corr-btn:hover{background:var(--blue);color:#fff}
.corr-btn:disabled{opacity:.4;cursor:not-allowed}
.q-feedback{margin-top:10px;padding:12px 16px;border-radius:10px;font-size:13px;line-height:1.6;display:none}
.q-feedback.ok{background:#EDFBF0;border-left:3px solid #22C55E;color:#166534}
.q-feedback.bof{background:#FFFBEB;border-left:3px solid #F59E0B;color:#92400E}
.q-feedback.ko{background:#FEF2F2;border-left:3px solid #EF4444;color:#991B1B}
.q-pts-earned{font-weight:700;margin-right:6px}
.ex-score-bar{margin-top:18px;padding-top:16px;border-top:1px solid rgba(0,0,0,.06)}
.ex-score-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.ex-score-label{font-size:12px;color:var(--muted)}
.ex-score-val{font-size:13px;font-weight:600;color:var(--ink)}
.ex-bar{height:7px;background:rgba(0,0,0,.06);border-radius:100px;overflow:hidden}
.ex-bar-fill{height:100%;border-radius:100px;background:var(--blue);transition:width .5s ease}
.score-panel{background:var(--blue);border-radius:20px;padding:36px;margin-top:12px;display:none}
.score-panel-inner{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:center}
.score-note{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:8px}
.score-big{font-size:72px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.04em}
.score-mention{display:inline-block;font-size:14px;font-weight:700;padding:6px 20px;border-radius:100px;margin-top:12px;text-transform:lowercase;letter-spacing:-.01em}
.score-bars{display:flex;flex-direction:column;gap:10px}
.score-ex-row{display:flex;align-items:center;gap:10px}
.score-ex-name{font-size:12px;color:rgba(255,255,255,.7);width:90px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.score-ex-bar{flex:1;height:6px;background:rgba(255,255,255,.15);border-radius:100px;overflow:hidden}
.score-ex-fill{height:100%;border-radius:100px;background:#fff;transition:width .6s ease}
.score-ex-pts{font-size:11px;font-weight:600;color:rgba(255,255,255,.6);flex-shrink:0;width:44px;text-align:right}

/* PAGE PARCOURS TABLEAU DE BORD */
.mention-scale{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:0}
.mention-card{background:var(--white);border-radius:14px;padding:22px;border-top:4px solid transparent;position:relative}
.mention-card.current{background:var(--blue)}
.mention-card-label{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px}
.mention-card-note{font-family:var(--fd);font-size:34px;font-weight:500;letter-spacing:-.03em;line-height:1;margin-bottom:4px}
.mention-card-range{font-size:12px;font-weight:300;margin-bottom:14px}
.mention-bar{height:5px;background:rgba(0,0,0,.06);border-radius:100px;overflow:hidden}
.mention-bar-fill{height:100%;border-radius:100px}
.mention-card-sub{font-size:11px;margin-top:7px;font-weight:300}
.mention-badge{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--orange);color:#fff;font-family:var(--fd);font-size:9px;font-weight:700;padding:3px 12px;border-radius:100px;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
</style>
