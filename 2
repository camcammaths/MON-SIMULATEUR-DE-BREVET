function genererBrevet() {
  var dureeEl = document.querySelector('.duree-chip.sel');
  var duree = dureeEl ? dureeEl.querySelector('span').textContent : '2h';
  var notions = [];
  var toutesNotions = false;
  if (document.querySelector('.notion-chip.all-chip.sel')) {
    toutesNotions = true;
  } else {
    document.querySelectorAll('.notion-chip.sel:not(.all-chip)').forEach(function(c) { notions.push(c.dataset.notion); });
  }
  var modeCorr = (document.querySelector('.corr-chip.sel') || { dataset: { mode: 'question' } }).dataset.mode;
  window._brevetMode = modeCorr;
  window._brevetData = null;
  window._scores = {};

  // Nombre d'exercices selon la durée
  var dureeEl2 = document.querySelector('.duree-chip.sel');
  var mins = dureeEl2 ? parseInt(dureeEl2.dataset.mins) : 120;
  var nbEx, qcmOnly;
  if (mins >= 120)      { nbEx = 5;  qcmOnly = false; }
  else if (mins >= 90)  { nbEx = 4;  qcmOnly = false; }
  else if (mins >= 60)  { nbEx = 3;  qcmOnly = false; }
  else if (mins >= 30)  { nbEx = 1;  qcmOnly = false; }
  else                  { nbEx = 1;  qcmOnly = true;  }

  // Filtrer selon notions + type
  var pool = EXERCICES_DB.filter(function(ex) {
    var notionOk = toutesNotions || notions.indexOf(ex.notion) !== -1;
    var typeOk = !qcmOnly || ex.id.indexOf('qcm') === 0;
    return notionOk && typeOk;
  });
  if (pool.length === 0) {
    pool = EXERCICES_DB.filter(function(ex) {
      return !qcmOnly || ex.id.indexOf('qcm') === 0;
    });
  }
  if (pool.length === 0) pool = EXERCICES_DB.slice();

  // Mélanger et sélectionner le bon nombre
  pool = pool.slice().sort(function() { return Math.random() - 0.5; });
  var selectionnes = pool.slice(0, nbEx).map(function(ex, i) {
    return Object.assign({}, ex, { numero: i + 1 });
  });

  showPage('brevet');
  document.getElementById('brevet-duree').textContent = duree;
  var labelNotions = toutesNotions ? 'Toutes les notions' : (notions.length ? notions.join(', ') : 'Toutes les notions');
  document.getElementById('brevet-notions').textContent = 'Notions : ' + labelNotions;

  window._brevetData = selectionnes;
  renderExercices(selectionnes, modeCorr);
  startTimer(duree);
}


function togglePricing(type) {
  var bm = document.getElementById('tog-month'), by = document.getElementById('tog-year');
  var pm = document.getElementById('price-main'), pp = document.getElementById('price-period'), ps = document.getElementById('price-sub');
  if (type === 'month') {
    bm.style.background = 'rgba(255,255,255,0.2)'; bm.style.color = '#fff';
    by.style.background = 'transparent'; by.style.color = 'rgba(255,255,255,0.5)';
    pm.textContent = '9€'; pp.textContent = '/mois'; ps.textContent = '7 jours essai gratuit sans CB';
  } else {
    by.style.background = 'rgba(255,255,255,0.2)'; by.style.color = '#fff';
    bm.style.background = 'transparent'; bm.style.color = 'rgba(255,255,255,0.5)';
    pm.textContent = '6€'; pp.textContent = '/mois'; ps.textContent = '72€/an · 2 mois offerts · sans engagement';
  }
}
function selectDuree(el) {
  document.querySelectorAll('.duree-chip').forEach(function(c) { c.classList.remove('sel'); });
  el.classList.add('sel');
  document.getElementById('recap-duree').textContent = el.querySelector('span').textContent;
}
function toggleNotion(el) {
  var isAll = el.dataset.notion === 'all';
  if (isAll) {
    document.querySelectorAll('.notion-chip').forEach(function(c) { c.classList.remove('sel'); c.querySelector('.ncheck').textContent = ''; });
    el.classList.add('sel'); el.querySelector('.ncheck').textContent = '✓';
  } else {
    var all = document.querySelector('.notion-chip[data-notion="all"]');
    all.classList.remove('sel'); all.querySelector('.ncheck').textContent = '';
    el.classList.toggle('sel');
    el.querySelector('.ncheck').textContent = el.classList.contains('sel') ? '✓' : '';
    if (!document.querySelectorAll('.notion-chip.sel:not([data-notion="all"])').length) {
      all.classList.add('sel'); all.querySelector('.ncheck').textContent = '✓';
    }
  }
  updateRecapNotions();
}
function updateRecapNotions() {
  var c = document.getElementById('recap-notions'); c.innerHTML = '';
  if (document.querySelector('.notion-chip.all-chip.sel')) {
    c.innerHTML = '<span class="recap-tag all">Toutes les notions</span>';
  } else {
    document.querySelectorAll('.notion-chip.sel:not(.all-chip)').forEach(function(n) {
      var t = document.createElement('span'); t.className = 'recap-tag'; t.textContent = n.dataset.notion; c.appendChild(t);
    });
  }
}
function selectCorr(el) {
  document.querySelectorAll('.corr-chip').forEach(function(c) {
    c.classList.remove('sel');
    var ck = c.querySelector('.ccheck');
    ck.textContent = ''; ck.style.background = ''; ck.style.borderColor = ''; ck.style.color = '';
  });
  el.classList.add('sel');
  var ck = el.querySelector('.ccheck');
  ck.textContent = '✓'; ck.style.background = 'var(--blue)'; ck.style.borderColor = 'var(--blue)'; ck.style.color = '#fff';
  document.getElementById('recap-corr').textContent = el.dataset.mode === 'question' ? 'question par question' : "à la fin de l'examen";
}
